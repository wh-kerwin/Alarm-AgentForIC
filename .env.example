# LLM explanation layer
# disabled | openai | deepseek | qwen
LLM_PROVIDER=disabled
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Reserved provider settings for future adapters
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Persistence roadmap
# Development default: SQLite
# Production target: PostgreSQL
DATABASE_URL=sqlite:///data/alarm_agent.db
# DATABASE_URL=postgresql://user:password@localhost:5432/alarm_agent

# Process knowledge vector database roadmap
CHROMA_PERSIST_DIRECTORY=data/chroma
CHROMA_COLLECTION=process_knowledge
